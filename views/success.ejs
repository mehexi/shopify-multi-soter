<!DOCTYPE html>
<html>
<head>
  <title>OAuth Success</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
          },
        },
      },
    }
  </script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="font-sans antialiased">
  <div class="container">
    <h1>🎉 OAuth Success!</h1>
    <p class="success">Your Shopify store has been authorized successfully!</p>

    <p><strong>Store:</strong> <%= shop %></p>
    <p><strong>Token:</strong> <%= accessToken %></p>

    <div class="info-box">
      <strong>App Used:</strong> <%= appType %>
    </div>

    <p>You can now manage this store from the dashboard.</p>
    <button onclick="window.location.href='/'">Go to Dashboard</button>
  </div>
</body>
</html>
