<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shopify Multi-Store Manager</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
</head>
<body>
  <div class="app-layout">
    <%- include('partials/sidebar') %>

    <div id="sidebarOverlay" class="sidebar-overlay"></div>

    <main class="main-content" id="mainContent">
      <header class="top-header">
        <button id="hamburgerBtn" class="hamburger-btn" aria-label="Toggle sidebar">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <h1 id="pageTitle" class="page-title">Dashboard</h1>
        <div class="header-badges">
          <button class="manual-topbar-btn" onclick="switchTab('manual')">
            <i data-lucide="file-text" class="icon-inline"></i> Manual Setup
          </button>
          <span class="badge badge-stores"><%= storeCount %> stores</span>
          <span class="badge badge-apps"><%= appCount %> apps</span>
        </div>
      </header>

      <div class="content-area">
        <%- include('partials/dashboard-tab') %>
        <%- include('partials/apps-tab') %>
        <%- include('partials/connect-tab') %>
        <%- include('partials/product-tab') %>
        <%- include('partials/manage-tab') %>
        <%- include('partials/manual-tab') %>
        <%- include('partials/delete-tab') %>
      </div>
    </main>
  </div>

  <script src="/js/app.js"></script>
  <script>lucide.createIcons();</script>
</body>
</html>
