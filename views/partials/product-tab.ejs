<div id="product-tab" class="tab-content">
  <% if (storeCount === 0) { %>
    <div class="no-stores">
      <h2>No stores connected yet!</h2>
      <p>Connect a store first to manage products.</p>
    </div>
  <% } else { %>
    <h2><i data-lucide="package" style="width:20px;height:20px;"></i> Product Management</h2>
    
    <div class="product-store-bar">
      <span class="product-store-label">Store:</span>
      <select id="productStoreSelect" class="dash-data-select" onchange="fetchProduct(this.value)" style="max-width:320px;">
        <% stores.forEach(shop => { %>
          <option value="<%= shop %>"><%= shop.replace('.myshopify.com', '') %></option>
        <% }) %>
      </select>
      <button class="btn-primary btn-small" onclick="toggleAddProductForm()" style="margin-left:auto;">
        <i data-lucide="plus" style="width:16px;height:16px;"></i> Add Product
      </button>
    </div>

    <div style="margin-top: 20px;">
      <button class="btn-primary btn-small" onclick="toggleAddProductForm()">
        <i data-lucide="plus" style="width:16px;height:16px;"></i> Add Product
      </button>
    </div>

    <div id="addProductForm" style="display:none; margin-top: 20px; padding: 20px; border: 1px solid var(--card-border); border-radius: var(--radius-md); background:var(--card-bg);">
      <h3>Add New Product</h3>

      <div style="display:flex; flex-direction:column; gap:10px; max-width:400px;">
        <select id="manageStore" class="input-field">
          <option value="all">All Stores</option>
          <% stores.forEach(shop => { %>
            <option value="<%= shop %>"><%= shop %></option>
          <% }) %>
        </select>

        <input id="productTitle" type="text" placeholder="Product Title *" class="input-field" />
        <input id="productPrice" type="number" placeholder="Price *" class="input-field" step="0.01" />
        <input id="productSku" type="text" placeholder="SKU" class="input-field" />
        <textarea id="productDescription" placeholder="Description" class="input-field" rows="3"></textarea>

        <button class="btn-primary btn-small" onclick="createProduct()">
          <i data-lucide="check-circle" style="width:16px;height:16px;"></i> Create Product
        </button>
      </div>

      <div id="manageResult" style="margin-top: 15px;"></div>
    </div>
    
    <div id="fetchProduct" style="margin-top:20px;"></div>
  <% } %>

    <div id="manualResult"></div>
</div>
