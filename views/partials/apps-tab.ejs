<div id="apps-tab" class="tab-content">
  <div class="info-box">
    <strong><i data-lucide="info" style="width:16px;height:16px;"></i> About Multiple Apps</strong>
    <p>Each Shopify store can have its own dedicated OAuth app. This is useful when:</p>
    <ul style="margin-left:20px; margin-top:10px;">
      <li>You manage stores for different clients</li>
      <li>Each store owner wants their own app</li>
      <li>You need different permission scopes per store</li>
    </ul>
  </div>

  <div class="apps-section">
    <h2><i data-lucide="key" style="width:18px;height:18px;"></i> Configured Apps: <%= appCount %></h2>
    <% if (appCount === 0) { %>
      <div class="no-stores">
        <p>No apps configured yet.</p>
        <a href="#" onclick="switchTab('connect'); return false;" class="btn" style="margin-top:12px;"><i data-lucide="plus" style="width:16px;height:16px;"></i> Add your first app</a>
      </div>
    <% } else { %>
      <% Object.entries(apps).forEach(([shop, app]) => { %>
        <div class="app-card">
          <div class="app-info">
            <strong><%= shop %></strong>
            <small>Client ID: <%= app.clientId %></small>
            <small>Client Secret: <%= app.clientSecret.substring(0, 20) %>...</small>
          </div>
          <div class="app-card-actions">
            <% if (!tokens[shop]) { %>
              <a href="/install?shop=<%= shop %>" class="btn btn-small"><i data-lucide="link" style="width:14px;height:14px;"></i> Connect</a>
            <% } else { %>
              <small style="color:var(--accent-success);"><i data-lucide="check-circle" style="width:14px;height:14px;"></i> Connected</small>
            <% } %>
            <button class="btn-danger btn-small" onclick="removeApp('<%= shop %>')">Remove</button>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>
